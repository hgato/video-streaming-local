{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "video-pipeline.02-transcode",
  "title": "video-pipeline.02-transcode",
  "description": "Incoming message consumed by encoder from the transcode topic. Produced by lifecycle-manager.",
  "type": "object",
  "required": ["metadata", "output_config"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["user_id", "video_id", "source_filename", "video_item_id"],
      "properties": {
        "user_id": {
          "type": "string",
          "description": "ID of the user who uploaded the video."
        },
        "video_id": {
          "type": "string",
          "description": "Unique identifier for the uploaded video."
        },
        "source_filename": {
          "type": "string",
          "description": "Original filename of the uploaded video in object storage."
        },
        "video_item_id": {
          "type": "string",
          "format": "uuid",
          "description": "UUID assigned by lifecycle-manager."
        }
      }
    },
    "output_config": {
      "type": "object",
      "description": "Transcoding configuration.",
      "properties": {
        "resolutions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of resolution labels to encode (e.g. 1080p, 720p, 480p)."
        },
        "format": {
          "type": "string",
          "description": "Output packaging format (e.g. hls)."
        }
      }
    }
  },
  "examples": [
    {
      "metadata": {
        "user_id": "usr_abc123",
        "video_id": "vid_def456",
        "source_filename": "raw/usr_abc123/vid_def456.mp4",
        "video_item_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
      },
      "output_config": {
        "resolutions": ["1080p", "720p", "480p"],
        "format": "hls"
      }
    }
  ]
}
